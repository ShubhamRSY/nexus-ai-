# LLM Providers (optional — configure in Nexus UI or here)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Twilio Telephony (optional)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# Vector DB
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=text-embedding-3-small

# CRM Integration (optional)
CRM_PROVIDER=hubspot
HUBSPOT_API_KEY=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Encrypted integrations vault
# Fernet key for data/integrations.vault — required in production for stable decryption
INTEGRATIONS_ENCRYPTION_KEY=
# Optional: require this token in X-Settings-Token header when saving credentials via API/UI
SETTINGS_ADMIN_TOKEN=
# Optional: HMAC secret for signing outbound n8n/Zapier webhook payloads
WEBHOOK_SIGNING_SECRET=

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
